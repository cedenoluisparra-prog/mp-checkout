# Mercado Pago access token (MP Dashboard → Your integrations → Credentials)
# Use TEST token for development, PROD token for production
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# MP webhook signing secret (MP Dashboard → Your integrations → Webhooks → Secret)
MP_WEBHOOK_SECRET=your-webhook-secret-here

# Allowed CORS origin — your frontend URL (no trailing slash)
ALLOWED_ORIGIN=https://your-app.vercel.app

# Supabase — these are injected automatically in Edge Functions, no need to set them manually
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
