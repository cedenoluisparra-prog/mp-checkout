# ─── Frontend (Vite) — agregar en Vercel como Environment Variables ──────────
# Clave pública de Mercado Pago (producción: APP_USR-..., sandbox: TEST-...)
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL y anon key de tu proyecto Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Supabase Edge Function (secreto, nunca al frontend) ─────────────────────
# Access Token de Mercado Pago (producción: APP_USR-..., sandbox: TEST-...)
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# Texto que aparece en el estado de cuenta del tarjetahabiente (máx. 22 caracteres)
MP_STATEMENT_DESCRIPTOR=MINEGOCIO
